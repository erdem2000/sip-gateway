# SIP Gateway configuration
# Copy to .env and fill in values before running docker-compose up

# Public IP of this host (the static GCE IP from terraform output)
EXTERNAL_IP=

# Internal/private IP of this host (GCE uses NAT; RTPEngine must bind to this)
# On GCE: curl -s -H "Metadata-Flavor: Google" http://metadata.google.internal/computeMetadata/v1/instance/network-interfaces/0/ip
INTERNAL_IP=

# Customer SBC address (IP or FQDN)
CUSTOMER_SBC_ADDRESS=

# Customer SBC SIP port (default: 5060)
CUSTOMER_SBC_PORT=5060

# Digest auth credentials (optional — leave empty to disable auth)
AUTH_USER=
AUTH_PASSWORD=
AUTH_REALM=
